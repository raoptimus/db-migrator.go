POSTGRES_DB=docker
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DSN=postgres://docker:docker@postgres:5432/docker?sslmode=disable
POSTGRES_MIGRATIONS_PATH=./fixtures/postgres
POSTGRES_RELEASE_MIGRATIONS_PATH=./fixtures/postgres_release

CLICKHOUSE_DSN=clickhouse://default:@clickhouse:9000/default?compress=true&debug=false
CLICKHOUSE_MIGRATIONS_PATH=./fixtures/clickhouse
CLICKHOUSE_RELEASE_MIGRATIONS_PATH=./fixtures/clickhouse_release
CLICKHOUSE_CLUSTER_DSN=clickhouse://default:@clickhouse1:9000,clickhouse2:9000/default?compress=true&debug=false
CLICKHOUSE_CLUSTER_R_DSN=clickhouse://default:@clickhouse-r-1:9000,clickhouse-r-2:9000/default?compress=true&debug=false&allow_experimental_database_replicated=1
MIGRATION_CLUSTER_NAME=test_cluster
CLICKHOUSE_CLUSTER_MIGRATIONS_PATH=./fixtures/clickhouse_cluster
CLICKHOUSE_CLUSTER_RELEASE_MIGRATIONS_PATH=./fixtures/clickhouse_cluster_release
CLICKHOUSE_CLUSTER_R_MIGRATIONS_PATH=./fixtures/clickhouse_cluster_replicated
CLICKHOUSE_CLUSTER_R_RELEASE_MIGRATIONS_PATH=./fixtures/clickhouse_cluster_replicated_release

MYSQL_DSN=mysql://docker:docker@tcp(mysql:3306)/docker
MYSQL_ROOT_PASSWORD=docker-pw
MYSQL_PASSWORD=docker
MYSQL_USER=docker
MYSQL_DATABASE=docker
MYSQL_MIGRATIONS_PATH=./fixtures//mysql
MYSQL_RELEASE_MIGRATIONS_PATH=./fixtures/mysql_release

TARANTOOL_DSN=tarantool://guest:@tarantool:3301/migrate
TARANTOOL_MIGRATIONS_PATH=./fixtures/tarantool
TARANTOOL_RELEASE_MIGRATIONS_PATH=./fixtures/tarantool_release
TT_MEMTX_USE_MVCC_ENGINE=true

# Iceberg REST Catalog (warehouse=iceberg)
# On host (via port 8181): iceberg://localhost:8181/iceberg?s3.endpoint=http://localhost:9002&s3.access-key-id=minioadmin&s3.secret-access-key=minioadmin&s3.region=us-east-1&s3.force-virtual-addressing=false
# Inside docker network: iceberg://iceberg-rest:8181/iceberg?s3.endpoint=http://minio:9000&...
ICEBERG_DSN=iceberg://iceberg-rest:8181/iceberg?s3.endpoint=http://minio:9000&s3.access-key-id=minioadmin&s3.secret-access-key=minioadmin&s3.region=us-east-1&s3.force-virtual-addressing=false
ICEBERG_MIGRATIONS_PATH=./fixtures/iceberg
ICEBERG_RELEASE_MIGRATIONS_PATH=./fixtures/iceberg_release
ICEBERG_RELEASE_FAIL_MIGRATIONS_PATH=./fixtures/iceberg_release_fail
ICEBERG_IRREVERSIBLE_MIGRATIONS_PATH=./fixtures/iceberg-irreversible

# MinIO credentials (used by iceberg-rest container)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
